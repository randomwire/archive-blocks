{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "archive-blocks/popular-terms",
    "version": "1.0.0",
    "title": "Popular Tags/Categories",
    "category": "widgets",
    "icon": "tag",
    "description": "Display popular tags or categories based on a weighted popularity score.",
    "textdomain": "archive-blocks",
    "attributes": {
        "taxonomy": {
            "type": "string",
            "default": "category"
        },
        "count": {
            "type": "number",
            "default": 10
        },
        "orderBy": {
            "type": "string",
            "default": "popular"
        },
        "exclude": {
            "type": "string",
            "default": ""
        },
        "separator": {
            "type": "string",
            "default": " / "
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"]
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php"
}
